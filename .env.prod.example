# Copy to .env.prod and edit before deploy: cp .env.prod.example .env.prod

# --- Public URL (no trailing slash; used for CORS & deploy hints) ---
# HTTP on port 80 — access via domain without :port
# Example: http://pool.example.com  or  http://123.45.67.89
PUBLIC_URL=http://pool.example.com
CORS_ORIGINS=http://pool.example.com

# --- Host port (maps to app :8790 inside container; use 80 for domain access) ---
APP_HTTP_PORT=80
CHATGPT_OAUTH_CALLBACK_PORT=1455

# --- MySQL (first boot only; changing password later needs manual DB steps) ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=codex_pool
MYSQL_USER=codex
MYSQL_PASSWORD=change-me-db

# DATABASE_URL is assembled in docker-compose.prod.yml from MYSQL_* vars.

# --- Redis (in compose network; do not expose publicly) ---
REDIS_URL=redis://redis:6379/0

# --- Admin login (created on first start if user does not exist) ---
JWT_SECRET=change-me-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin

# --- ChatGPT OAuth (optional; callback stays on :1455) ---
CHATGPT_AUTH_DIR=/data/.codex-pool/auth
CHATGPT_OAUTH_REDIRECT_URI=http://pool.example.com:1455/auth/callback
CHATGPT_OAUTH_CALLBACK_PORT=1455

# --- Billing (DB-backed in production) ---
BILLING_STUB_ENABLED=false

# --- Optional: mirror base images (China) ---
# NODE_BASE_IMAGE=docker.1ms.run/library/node:22-alpine
# PYTHON_BASE_IMAGE=docker.1ms.run/library/python:3.12-slim
# CODEX_POOL_IMAGE_TAG=prod
