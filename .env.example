# Copy to .env and edit. Do not commit .env.

# --- Database (required) ---
DATABASE_URL=mysql+pymysql://codex:codex@127.0.0.1:3307/codex_pool
REDIS_URL=redis://127.0.0.1:6379/0

# --- Admin API + Codex proxy + Web UI (single port, default 8790) ---
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
CORS_ORIGINS=http://localhost:5173
# WEB_DIST=./web/dist   # optional; auto-detected when web/dist exists

# --- Billing simulation (optional) ---
BILLING_STUB_ENABLED=true
BILLING_BUDGET_USD=50
BILLING_STATE_FILE=~/.codex-pool/usage.json
BILLING_DEFAULT_INPUT_PER_1M=5.0
BILLING_DEFAULT_OUTPUT_PER_1M=30.0
BILLING_DEFAULT_CACHED_PER_1M=0.5

# --- ChatGPT OAuth (optional; defaults match Codex CLI) ---
# CHATGPT_AUTH_DIR=~/.codex-pool/auth
# CHATGPT_OAUTH_CALLBACK_PORT=1455
# CHATGPT_OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
# CHATGPT_USAGE_URL=https://chatgpt.com/backend-api/wham/usage
