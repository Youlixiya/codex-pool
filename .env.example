# Copy to .env and edit. Do not commit .env.

# --- Database (optional; default ~/.codex-pool/codex_pool.db) ---
# DATABASE_URL=sqlite:////absolute/path/to/codex_pool.db

JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:8790

# --- Billing (usage cost written to SQLite; prices per 1M tokens) ---
BILLING_BUDGET_USD=50
BILLING_DEFAULT_INPUT_PER_1M=5.0
BILLING_DEFAULT_OUTPUT_PER_1M=30.0
BILLING_DEFAULT_CACHED_PER_1M=0.5

# --- ChatGPT OAuth (optional) ---
CHATGPT_AUTH_DIR=~/.codex-pool/auth
CHATGPT_OAUTH_CALLBACK_PORT=1455
CHATGPT_OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
# CHATGPT_USAGE_URL=https://chatgpt.com/backend-api/wham/usage

# WEB_DIST=./web/dist
